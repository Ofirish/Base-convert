                lastFromBaseForExplanation = from;
                lastToExplainBase = target;
                generateExplanation(input, from, target);
            });

            document.getElementById('copy-btn').onclick = () => {
                let textToCopy = '';
                if (!document.getElementById('converter-tab-outputs').classList.contains('hidden')) {
                    textToCopy = document.getElementById('converter-results').textContent;
                } else {
                    textToCopy = lastTutorFullContent;
                }
                navigator.clipboard.writeText(textToCopy).then(() => showMessageBox(langData[currentLang].copySuccess));
            };

            document.getElementById('copy-explanation-btn').onclick = () => {
                navigator.clipboard.writeText(currentPlainTextExplanation).then(() => showMessageBox(langData[currentLang].copySuccess));
            };

            document.getElementById('copy-tutor-visual').onclick = () => {
                navigator.clipboard.writeText(lastTutorVisualContent).then(() => showMessageBox(langData[currentLang].copySuccess));
            };

            document.getElementById('copy-tutor-full').onclick = () => {
                navigator.clipboard.writeText(lastTutorFullContent).then(() => showMessageBox(langData[currentLang].copySuccess));
            };

            document.getElementById('copy-tutor-steps').onclick = () => {
                navigator.clipboard.writeText(lastTutorStepsContent).then(() => showMessageBox(langData[currentLang].copySuccess));
            };
        });
    </script>
</body>
</html>
