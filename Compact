        const messageBox = document.getElementById('message-box');
        function showMessageBox(message, duration = 2000) {
            messageBox.textContent = message;
            messageBox.classList.add('show');
            setTimeout(() => messageBox.classList.remove('show'), duration);
        }

        function getPrecision() {
            const val = parseInt(document.getElementById('decimal-places').value);
            return isNaN(val) ? 8 : val;
        }

        function cleanFloat(num, prec) {
            const p = typeof prec === 'undefined' ? getPrecision() : prec;
            return parseFloat(num.toFixed(p));
        }

        function toDecimal(number, base) {
            if (typeof number !== 'string') number = String(number);
            if (number.includes('/')) {
                const parts = number.split('/');
                if (parts.length !== 2) return null;
                const num = toDecimal(parts[0], base);
                const den = toDecimal(parts[1], base);
                return (num !== null && den !== null && den !== 0) ? cleanFloat(num / den) : null;
            }
            const parts = number.toUpperCase().split('.');
            let decimalValue = 0;
            const intDigits = parts[0].split('').reverse();
            for (let i = 0; i < intDigits.length; i++) {
                let val = digitsMap.indexOf(intDigits[i]);
                if (val === -1 || val >= base) return null;
                decimalValue += val * Math.pow(base, i);
            }
            if (parts.length === 2) {
                const fracDigits = parts[1].split('');
                for (let i = 0; i < fracDigits.length; i++) {
                    let val = digitsMap.indexOf(fracDigits[i]);
                    if (val === -1 || val >= base) return null;
                    decimalValue += val * Math.pow(base, -(i + 1));
                }
            } else if (parts.length > 2) return null;
            return cleanFloat(decimalValue);
        }

        function fromDecimal(number, base) {
            if (number === 0) return "0";
            let isNegative = number < 0;
            number = Math.abs(number);
            let intPart = Math.floor(number);
            let fracPart = number - intPart;
            let result = "";
            if (intPart === 0) result = "0";
            else {
                let tempInt = intPart;
                while (tempInt > 0) {
                    result = digitsMap[tempInt % base] + result;
                    tempInt = Math.floor(tempInt / base);
                }
            }
            if (fracPart > 0) {
                let fracResult = "";
                let count = 0;
                let tempFrac = fracPart;
                const prec = getPrecision();
                while (tempFrac > 0 && count < prec) {
                    tempFrac = cleanFloat(tempFrac * base, prec + 2);
                    let digit = Math.floor(tempFrac);
                    fracResult += digitsMap[digit];
                    tempFrac = cleanFloat(tempFrac - digit, prec + 2);
                    count++;
                }
                if (fracResult.length > 0) result += "." + fracResult;
            }
            return (isNegative ? "-" : "") + result;
        }

        function validateInput(number, base) {
            if (!number) return false;
            let validChars = digitsMap.substring(0, base);
            let pattern = new RegExp(`^[${validChars}\\.\\/]+$`, 'i');
            if (!pattern.test(number)) return false;
            if (number.includes('.') && number.includes('/')) return false;
            if ((number.match(/\./g) || []).length > 1) return false;
            if ((number.match(/\//g) || []).length > 1) return false;
            return true;
        }

        function getFullRepresentation(decimalVal) {
            const b = fromDecimal(decimalVal, 2);
            const o = fromDecimal(decimalVal, 8);
            const d = decimalVal;
            const h = fromDecimal(decimalVal, 16);
            return `[Bin: ${b}, Oct: ${o}, Dec: ${d}, Hex: ${h}]`;
        }

        function removeEmojis(str) {
            return str.replace(/([\u2700-\u27BF]|[\uE000-\uF8FF]|\uD83C[\uDC00-\uDFFF]|\uD83D[\uDC00-\uDFFF]|[\u2011-\u26FF]|\uD83E[\uDD10-\uDDFF])/g, '');
        }

        function calculateBinaryCarries(a, b, op) {
            let maxLen = Math.max(a.length, b.length);
            let s1 = a.padStart(maxLen, '0');
            let s2 = b.padStart(maxLen, '0');
            let carries = new Array(maxLen).fill('0');
            let c = 0;
            if (op === '+') {
                for (let i = maxLen - 1; i >= 0; i--) {
                    let sum = parseInt(s1[i]) + parseInt(s2[i]) + c;
                    c = sum > 1 ? 1 : 0;
                    if (i > 0) carries[i - 1] = String(c);
                }
            } else if (op === '-') {
                let borrow = 0;
                for (let i = maxLen - 1; i >= 0; i--) {
                    let v1 = parseInt(s1[i]) - borrow;
                    let v2 = parseInt(s2[i]);
                    if (v1 < v2) borrow = 1;
                    else borrow = 0;
                    if (i > 0) carries[i - 1] = String(borrow);
                }
            }
            return carries;
        }

        function generateVisualization(op, term1Bin, term2Bin, resBin) {
            const lang = langData[currentLang];
            const t1 = term1Bin.replace('-', '');
            const t2 = term2Bin.replace('-', '');
            const res = resBin.replace('-', '');
            let html = "";
            let textOnly = "";
            if (op === '*') {
                const b = t2.split('').reverse();
                const rows = [];
                for (let i = 0; i < b.length; i++) {
                    if (b[i] === '1') rows.push(t1 + '0'.repeat(i));
                    else rows.push('0'.repeat(t1.length + i));
                }
                const maxLen = Math.max(res.length, ...rows.map(r => r.length));
                let colStr = lang.visCol.padEnd(10);
                for (let i = maxLen; i >= 1; i--) colStr += i + " ";
                html += colStr + "\n" + "-".repeat(colStr.length) + "\n";
                textOnly += colStr + "\n" + "-".repeat(colStr.length) + "\n";
                rows.forEach((r, idx) => {
                    let rowLabel = `${lang.visRow} ${idx + 1}:`.padEnd(10);
                    let rowContent = r.split('').join(' ').padStart((maxLen * 2) - 1);
                    html += rowLabel + rowContent + "\n";
                    textOnly += rowLabel + rowContent + "\n";
                });
                html += "-".repeat(colStr.length) + "\n";
                let resStr = `${lang.visRes.padEnd(10)}` + res.split('').join(' ').padStart((maxLen * 2) - 1);
                html += resStr;
                textOnly += "-".repeat(colStr.length) + "\n" + resStr;
            } else {
                const maxLen = Math.max(t1.length, t2.length, res.length);
                const carries = calculateBinaryCarries(t1, t2, op);
                let colStr = lang.visCol.padEnd(10);
                for (let i = maxLen; i >= 1; i--) colStr += i + " ";
                html += colStr + "\n" + "-".repeat(colStr.length) + "\n";
                textOnly += colStr + "\n" + "-".repeat(colStr.length) + "\n";
                let carryLabel = (op === '+' ? lang.visCarry : lang.visBorrow).padEnd(10);
                let carryContentHtml = carries.map(c => c === '1' ? `<span class="carry-bit">1</span>` : '0').join(' ').padStart((maxLen * 2) - 1);
                let carryContentPlain = carries.join(' ').padStart((maxLen * 2) - 1);
                html += carryLabel + carryContentHtml + "\n";
                textOnly += carryLabel + carryContentPlain + "\n";
                let r1 = `${lang.visRow} 1:`.padEnd(10) + t1.padStart(maxLen, '0').split('').join(' ').padStart((maxLen * 2) - 1) + "\n";
                let r2 = `${op} ${lang.visRow} 2:`.padEnd(10) + t2.padStart(maxLen, '0').split('').join(' ').padStart((maxLen * 2) - 1) + "\n";
                html += r1 + r2 + "-".repeat(colStr.length) + "\n";
                textOnly += r1 + r2 + "-".repeat(colStr.length) + "\n";
                let resStr = (op === '+' ? lang.visSum : lang.visRes).padEnd(10) + res.padStart(maxLen, '0').split('').join(' ').padStart((maxLen * 2) - 1);
                html += resStr;
                textOnly += resStr;
            }
            lastTutorVisualContent = textOnly;
            return html;
        }

        function binaryShortcutMethod(binString, groupSize, base) {
            const lang = langData[currentLang];
            let isNegative = binString.startsWith('-');
            let cleanBin = binString.replace('-', '');
            let parts = cleanBin.split('.');
            let intPart = parts[0];
            let fracPart = parts[1] || "";
            const stepLabel = base === 16 ? lang.tutorStep3Hex : lang.tutorStep3Oct;
            let steps = `${stepLabel}:\n${lang.shortcutStepGroup(groupSize)}\n`;
            while (intPart.length % groupSize !== 0) intPart = '0' + intPart;
            let intGroups = [];
            let intResult = "";
            for (let i = 0; i < intPart.length; i += groupSize) {
                let chunk = intPart.substring(i, i + groupSize);
                let digit = parseInt(chunk, 2).toString(base).toUpperCase();
                intGroups.push(chunk);
                intResult += digit;
            }
            let fracResult = "";
            let fracGroups = [];
            if (fracPart) {
                while (fracPart.length % groupSize !== 0) fracPart += '0';
                for (let i = 0; i < fracPart.length; i += groupSize) {
                    let chunk = fracPart.substring(i, i + groupSize);
                    let digit = parseInt(chunk, 2).toString(base).toUpperCase();
                    fracGroups.push(chunk);
                    fracResult += digit;
                }
            }
            let finalResultStr = (isNegative ? "-" : "") + intResult.replace(/^0+(?!$)/, '') + (fracResult ? "." + fracResult : "");
            steps += `${lang.shortcutGroupsLabel} ${intGroups.join(' ')} ${fracPart ? '. ' + fracGroups.join(' ') : ''}\n${lang.shortcutResultLabel} ${finalResultStr}(${base})`;
            return { steps, finalResult: finalResultStr };
        }

        function generateBinaryTableForTutor(decimalValue, resBin) {
            const data = langData[currentLang];
            const prec = getPrecision();
            let intPart = Math.floor(Math.abs(decimalValue));
            let tableHTML = `<div style="padding: 10px; border-top: 1px solid #e2e8f0; margin-top:10px;"><h4 class="font-bold mb-2">${data.binaryTableTitle(decimalValue)}</h4>`;
            tableHTML += '<div class="table-wrapper"><table class="binary-conversion-table"><thead><tr>';
            let powers = [];
            let values = [];
            let bits = [];
            let highestPower = intPart > 0 ? Math.floor(Math.log2(intPart)) : 0;
            for (let p = highestPower; p >= 0; p--) { powers.push(p); values.push(Math.pow(2, p)); }
            const binaryParts = resBin.replace('-', '').split('.');
            if (binaryParts[1]) {
                for (let i = 0; i < binaryParts[1].length; i++) {
                    powers.push(-(i + 1)); values.push(Math.pow(2, -(i + 1)));
                }
            }
            tableHTML += `<th>${data.rowPower}</th>`;
            powers.forEach(p => tableHTML += `<th>2<sup>${p}</sup></th>`);
            tableHTML += '</tr></thead><tbody><tr><td>' + data.rowValue + '</td>';
            values.forEach(v => tableHTML += `<td>${cleanFloat(v, prec)}</td>`);
            tableHTML += '</tr><tr><td>' + data.rowBit + '</td>';
            let tempValTable = Math.abs(decimalValue);
            powers.forEach(p => {
                let val = Math.pow(2, p);
                let bit = tempValTable >= val - 0.0000000001 ? 1 : 0;
                bits.push(bit);
                if (bit) tempValTable = cleanFloat(tempValTable - val, prec + 5);
                tableHTML += `<td>${bit}</td>`;
            });
            tableHTML += '</tr></tbody></table></div></div>';
            return tableHTML;
        }

        function solveExercise() {
            const inputRaw = document.getElementById('exercise-input').value.toLowerCase();
            const textOutput = document.getElementById('tutor-text-output');
            const tableOutput = document.getElementById('tutor-table-output');
            const visOutput = document.getElementById('tutor-visual-output');
            const lang = langData[currentLang];
            tableOutput.innerHTML = "";
            let operator = '';
            if (inputRaw.includes('+')) operator = '+';
            else if (inputRaw.includes('-')) operator = '-';
            else if (inputRaw.includes('*')) operator = '*';
            else if (inputRaw.includes('/')) operator = '/';
            if (!operator) {
                textOutput.innerText = currentLang === 'he' ? "פורמט לא תקין." : "Invalid format.";
                return;
            }
            const operands = inputRaw.split(operator).map(s => s.trim());
            let fullExpl = `${lang.tutorStep1}:\n`;
            let stepsOnly = "";
            let decimalTerms = [];
            let binaryTerms = [];
            for (let i = 0; i < operands.length; i++) {
                const termRegex = /([0-9a-f.]+)\s*\(\s*([a-z0-9]+)\s*\)/;
                const match = operands[i].match(termRegex);
                let val, base;
                if (match) {
                    val = match[1];
                    base = baseAlias[match[2]] || parseInt(match[2]);
                } else {
                    val = operands[i];
                    base = 10;
                }
                let dec = toDecimal(val, base);
                if (dec === null) {
                    textOutput.innerText = `${lang.invalidNumber}: ${val}`;
                    return;
                }
                let bin = fromDecimal(dec, 2);
                decimalTerms.push(dec);
                binaryTerms.push(bin);
                let line = `${val}(${base}) ➔ ${getFullRepresentation(dec)}\n`;
                fullExpl += line;
                stepsOnly += line;
            }
            let resDec;
            let opExpl = '';
            if (operator === '+') {
                resDec = decimalTerms[0] + decimalTerms[1]; opExpl = lang.opExplAdd;
            } else if (operator === '-') {
                resDec = decimalTerms[0] - decimalTerms[1]; opExpl = lang.opExplSub;
            } else if (operator === '*') {
                resDec = decimalTerms[0] * decimalTerms[1]; opExpl = lang.opExplMul;
            } else if (operator === '/') {
                if (decimalTerms[1] === 0) { textOutput.innerText = lang.divByZeroErr; return; }
                resDec = decimalTerms[0] / decimalTerms[1]; opExpl = lang.opExplDiv;
            }
            let resBin = fromDecimal(resDec, 2);
            let mathHeader = `\n${lang.tutorStep2} (${operator}):\n${opExpl}\n`;
            let vW = Math.max(binaryTerms[0].length, binaryTerms[1].length);
            let mathVisual = ` ${binaryTerms[0].padStart(vW)}\n${operator} ${binaryTerms[1].padStart(vW)}\n${'-'.repeat(vW + 4)}\n ${resBin.padStart(vW)}(2)\n`;
            fullExpl += mathHeader + mathVisual;
            stepsOnly += mathHeader + mathVisual;
            let finalStepExpl = "";
            let finalAns = "";
            const bnHex = currentLang === 'he' ? 'הקסדצימלי' : 'Hex';
            const bnOct = currentLang === 'he' ? 'אוקטלי' : 'Octal';
            if (tutorTargetBase === 16) {
                if (tutorTargetMode === 'short') {
                    let res = binaryShortcutMethod(resBin, 4, 16);
                    finalStepExpl = res.steps; finalAns = res.finalResult;
                } else {
                    finalStepExpl = `${lang.tutorStep3Std(bnHex)}:\n${resBin}(2) ➔ ${resDec}(10) ➔ ${fromDecimal(resDec, 16)}(16)`;
                    finalAns = fromDecimal(resDec, 16);
                }
            } else if (tutorTargetBase === 8) {
                if (tutorTargetMode === 'short') {
                    let res = binaryShortcutMethod(resBin, 3, 8);
                    finalStepExpl = res.steps; finalAns = res.finalResult;
                } else {
                    finalStepExpl = `${lang.tutorStep3Std(bnOct)}:\n${resBin}(2) ➔ ${resDec}(10) ➔ ${fromDecimal(resDec, 8)}(8)`;
                    finalAns = fromDecimal(resDec, 8);
                }
            } else if (tutorTargetBase === 10) {
                finalStepExpl = `${lang.tutorStep3Dec}:\n${resBin}(2) ➔ ${resDec}(10)\n`;
                finalAns = resDec;
            } else {
                finalStepExpl = `${lang.tutorStep3Bin}:\n${resBin}(2)`;
                finalAns = resBin;
                if (tutorTargetMode === 'table') tableOutput.innerHTML = generateBinaryTableForTutor(resDec, resBin);
            }
            fullExpl += `\n${finalStepExpl}`;
            stepsOnly += `\n${lang.tutorFinalAnsLabel} ${getFullRepresentation(resDec)}`;
            textOutput.innerText = fullExpl;
            visOutput.innerHTML = generateVisualization(operator, binaryTerms[0], binaryTerms[1], resBin);
            document.getElementById('visual-area').classList.remove('hidden');
            lastTutorFullContent = fullExpl;
            lastTutorStepsContent = stepsOnly;
            lastTutorFinalResult = getFullRepresentation(resDec);
            document.getElementById('tutor-copy-buttons').classList.remove('hidden');
            document.getElementById('copy-btn').classList.remove('hidden');
        }

        function generateExplanation(inputNum, srcBase, targetBase) {
            const explanationContent = document.getElementById('explanation-content');
            const explanationSection = document.getElementById('explanation-container');
            explanationContent.innerHTML = '';
            explanationSection.classList.remove('hidden');
            
            if (!validateInput(inputNum, srcBase)) {
                explanationContent.textContent = langData[currentLang].invalidNumber;
                return;
            }
            let decimalValue = toDecimal(inputNum, srcBase);
            if (decimalValue === null) {
                explanationContent.textContent = langData[currentLang].invalidNumber;
                return;
            }
            let explanationHTML = '';
            let plainTextContent = '';
            const data = langData[currentLang];
            const prec = getPrecision();
            if (srcBase !== 10) {
                const title = data.expToDecTitle(inputNum, srcBase);
                explanationHTML += `<h4 class="font-bold text-slate-700 mt-2 mb-1">${title}</h4>`;
                plainTextContent += removeEmojis(title) + '\n';
                if (inputNum.includes('/')) {
                    const parts = inputNum.split('/');
                    const line = `Fraction: ${parts[0]} / ${parts[1]} = ${decimalValue}`;
                    explanationHTML += `<p class="ml-2">${line}</p>`;
                    plainTextContent += line + '\n';
                } else {
                    const parts = inputNum.toUpperCase().split('.');
                    const intDigits = parts[0].split('').reverse();
                    for (let i = 0; i < intDigits.length; i++) {
                        let val = digitsMap.indexOf(intDigits[i]);
                        let term = cleanFloat(val * Math.pow(srcBase, i), prec);
                        let line = data.expToDecBody(intDigits[i], i, val, srcBase, term);
                        explanationHTML += `<p class="ml-2">${line}</p>`;
                        plainTextContent += line + '\n';
                    }
                    if (parts[1]) {
                        const fracDigits = parts[1].split('');
                        for (let i = 0; i < fracDigits.length; i++) {
                            let val = digitsMap.indexOf(fracDigits[i]);
                            let term = cleanFloat(val * Math.pow(srcBase, -(i + 1)), prec);
                            let line = `Digit '${fracDigits[i]}' at pos -${i+1}: ${val} * (${srcBase}^-${i+1}) = ${term}`;
                            explanationHTML += `<p class="ml-2">${line}</p>`;
                            plainTextContent += line + '\n';
                        }
                    }
                    explanationHTML += `<p class="ml-2 font-bold text-slate-800 mt-1">${data.expFinalSum(decimalValue)}</p>`;
                    plainTextContent += `Final Sum: ${decimalValue}\n\n`;
                }
            }
            if (targetBase !== 10 || (srcBase === 10 && targetBase === 2)) {
                const title = data.expFromDecTitle(decimalValue, targetBase);
                explanationHTML += `<h4 class="font-bold text-slate-700 mt-3 mb-1">${title}</h4>`;
                plainTextContent += removeEmojis(title) + '\n';
                let intPart = Math.floor(decimalValue);
                let fracPart = cleanFloat(decimalValue - intPart, prec);
                let tempInt = intPart;
                let intSteps = [];
                while (tempInt > 0) {
                    let rem = tempInt % targetBase;
                    let next = Math.floor(tempInt / targetBase);
                    intSteps.push({current: tempInt, next, rem, digit: digitsMap[rem]});
                    tempInt = next;
                }
                if (intPart === 0) intSteps.push({current: 0, next: 0, rem: 0, digit: '0'});
                intSteps.forEach(s => {
                    let line = data.expFromDecBody(s.current, targetBase, s.next, s.rem, s.digit);
                    explanationHTML += `<p class="ml-2">${line}</p>`;
                    plainTextContent += line + '\n';
                });
                if (fracPart > 0) {
                    explanationHTML += `<h4 class="font-bold text-slate-700 mt-2 mb-1">${data.expFracFromDecTitle(decimalValue, targetBase)}</h4>`;
                    let tempFrac = fracPart;
                    let count = 0;
                    while (tempFrac > 0 && count < prec) {
                        let product = cleanFloat(tempFrac * targetBase, prec + 2);
                        let digit = Math.floor(product);
                        let line = data.expFracFromDecBody(tempFrac, targetBase, product, digitsMap[digit]);
                        explanationHTML += `<p class="ml-2">${line}</p>`;
                        plainTextContent += line + '\n';
                        tempFrac = cleanFloat(product - digit, prec + 2);
                        count++;
                    }
                }
                const finalResult = fromDecimal(decimalValue, targetBase);
                explanationHTML += `<p class="ml-2 font-bold text-slate-800 mt-1">${data.expReadRemainders(finalResult)}</p>`;
                plainTextContent += `Final Result: ${finalResult}\n`;
                if (targetBase === 2) {
                    explanationHTML += generateBinaryTableForTutor(decimalValue, finalResult);
                }
            }
            explanationContent.innerHTML = explanationHTML;
            currentPlainTextExplanation = plainTextContent.trim();
        }

